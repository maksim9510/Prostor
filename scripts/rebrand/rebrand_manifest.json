{
  "_comment": "Rebrand manifest — files that MUST be rebranded after upstream sync. Run: python scripts/rebrand/apply_rebrand.py",
  "_updated": "2026-06-25",
  "python_imports": {
    "pattern": "from hermes_cli\\.|import hermes_cli\\.|from hermes_constants|import hermes_constants",
    "replacement": {
      "from hermes_cli.": "from prostor_cli.",
      "import hermes_cli.": "import prostor_cli.",
      "from hermes_constants": "from prostor_constants",
      "import hermes_constants": "import prostor_constants"
    },
    "dirs": [
      "prostor_cli/",
      "agent/",
      "tools/",
      "gateway/",
      "scripts/"
    ],
    "exclude": [
      "hermes_cli/"
    ]
  },
  "python_names": {
    "pattern": "\\bhermes_home\\b|\\bHERMES_HOME\\b|\\bhermes_cli\\b|\\bHERMES_CLI\\b|\\bhermes_constants\\b",
    "replacement": {
      "hermes_home": "prostor_home",
      "HERMES_HOME": "PROSTOR_HOME",
      "hermes_cli": "prostor_cli",
      "HERMES_CLI": "PROSTOR_CLI",
      "hermes_constants": "prostor_constants"
    },
    "skip_patterns": [
      "HERMES_HOME.*=.*os\\.environ",
      "os\\.environ.*HERMES_HOME",
      "# .*HERMES_HOME",
      "env var.*HERMES_HOME"
    ],
    "comment": "Skip env var names and comments — HERMES_HOME env var must stay for backward compat"
  },
  "python_functions": {
    "pattern": "normalizeHermesHomeRoot|get_hermes_home|ensure_hermes_home|load_hermes_dotenv",
    "replacement": {
      "normalizeHermesHomeRoot": "normalizeProstorHomeRoot",
      "get_hermes_home": "get_prostor_home",
      "ensure_hermes_home": "ensure_prostor_home",
      "load_hermes_dotenv": "load_prostor_dotenv"
    }
  },
  "typescript_imports": {
    "pattern": "from '@/hermes'|from '@/types/hermes'",
    "replacement": {
      "from '@/hermes'": "from '@/prostor'",
      "from '@/types/hermes'": "from '@/types/prostor'"
    },
    "dirs": [
      "apps/desktop/src/"
    ]
  },
  "typescript_names": {
    "pattern": "hermesDesktop|HermesConfigRecord|getHermesConfigRecord|hermesActiveSessions|startingHermesDesktop|updateHermes|HermesWindowState",
    "replacement": {
      "hermesDesktop": "prostorDesktop",
      "HermesConfigRecord": "ProstorConfigRecord",
      "getHermesConfigRecord": "getProstorConfigRecord",
      "hermesActiveSessions": "prostorActiveSessions",
      "startingHermesDesktop": "startingProstorDesktop",
      "updateHermes": "updateProstor",
      "HermesWindowState": "ProstorWindowState"
    },
    "dirs": [
      "apps/desktop/src/"
    ]
  },
  "electron_cjs": {
    "pattern": "hermesDesktop|normalizeHermesHomeRoot",
    "replacement": {
      "hermesDesktop": "prostorDesktop",
      "normalizeHermesHomeRoot": "normalizeProstorHomeRoot"
    },
    "dirs": [
      "apps/desktop/electron/"
    ]
  },
  "i18n": {
    "pattern": "hermesActiveSessions|startingHermesDesktop|updateHermes|guiSkewBody.*Hermes",
    "replacement": {
      "hermesActiveSessions": "prostorActiveSessions",
      "startingHermesDesktop": "startingProstorDesktop",
      "updateHermes": "updateProstor"
    },
    "dirs": [
      "apps/desktop/src/i18n/"
    ]
  },
  "protected_files": [
